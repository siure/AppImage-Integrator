rm -rf AppDir appimage-build dist

podman run --rm -it -v "$PWD:/work:Z" -w /work docker.io/library/ubuntu:24.04 bash -lc '
set -euo pipefail
export DEBIAN_FRONTEND=noninteractive

apt-get update
apt-get install -y \
  ca-certificates \
  desktop-file-utils \
  dpkg-dev \
  file \
  gtk-update-icon-cache \
  libfuse2t64 \
  libgdk-pixbuf2.0-bin \
  libglib2.0-bin \
  librsvg2-common \
  patchelf \
  python3 \
  python3-pip \
  python3-venv \
  squashfs-tools \
  zsync

python3 -m venv /tmp/appimage-builder-venv
. /tmp/appimage-builder-venv/bin/activate
pip install --upgrade pip
pip install "packaging<22" "appimage-builder==1.1.0"

./scripts/build-appimage.sh
'
