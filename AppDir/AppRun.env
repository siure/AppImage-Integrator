APPDIR=$ORIGIN
APPIMAGE_UUID=mR9YhiW
APPDIR_EXEC_PATH=$APPDIR/usr/bin/python3
APPDIR_EXEC_ARGS="${APPDIR}/usr/bin/appimage-integrator" $@
XDG_DATA_DIRS=$APPDIR/usr/share
XDG_CONFIG_DIRS=$APPDIR/etc/xdg:$XDG_CONFIG_DIRS
APPDIR_LIBRARY_PATH=$APPDIR/lib/x86_64-linux-gnu:$APPDIR/usr/lib/x86_64-linux-gnu:$APPDIR/usr/lib/x86_64-linux-gnu/cryptsetup:$APPDIR/usr/lib/x86_64-linux-gnu/gdk-pixbuf-2.0/2.10.0/loaders:$APPDIR/usr/lib/x86_64-linux-gnu/krb5/plugins/preauth:$APPDIR/usr/lib/x86_64-linux-gnu/sasl2:$APPDIR/usr/lib/x86_64-linux-gnu/security:$APPDIR/usr/lib/x86_64-linux-gnu/systemd:$APPDIR/lib/x86_64
PATH=$APPDIR/etc/init.d:$APPDIR/etc/security:$APPDIR/usr/bin:$APPDIR/usr/lib/dbus-1.0:$APPDIR/usr/lib/kernel/install.d:$APPDIR/usr/lib/python3.12:$APPDIR/usr/lib/python3.12/encodings:$APPDIR/usr/lib/python3.12/test:$APPDIR/usr/lib/python3.12/test/support:$APPDIR/usr/lib/systemd:$APPDIR/usr/lib/systemd/system-generators:$APPDIR/usr/lib/systemd/user-environment-generators:$APPDIR/usr/lib/systemd/user-generators:$APPDIR/usr/lib/x86_64-linux-gnu/gdk-pixbuf-2.0:$APPDIR/usr/lib/x86_64-linux-gnu/glib-2.0:$APPDIR/usr/libexec:$APPDIR/usr/libexec/coreutils:$APPDIR/usr/sbin:$APPDIR/usr/share/bug:$APPDIR/usr/share/bug/systemd:$APPDIR/usr/share/libgcrypt20:$APPDIR/usr/share/python3:$APPDIR/usr/share/python3/runtime.d:$PATH
GDK_PIXBUF_MODULEDIR=$APPDIR/usr/lib/x86_64-linux-gnu/gdk-pixbuf-2.0/2.10.0/loaders
GDK_PIXBUF_MODULE_FILE=$APPDIR/usr/lib/x86_64-linux-gnu/gdk-pixbuf-2.0/2.10.0/loaders.cache
GIO_MODULE_DIR=$APPDIR/usr/lib/x86_64-linux-gnu/gio/modules
GSETTINGS_SCHEMA_DIR=$APPDIR/usr/share/glib-2.0/schemas
GI_TYPELIB_PATH=$APPDIR/usr/lib/x86_64-linux-gnu/girepository-1.0
GTK_EXE_PREFIX=$APPDIR/usr
GTK_DATA_PREFIX=$APPDIR/usr
GTK_PATH=$APPDIR/usr/lib/x86_64-linux-gnu/gtk-4.0
APPDIR_LIBC_LIBRARY_PATH=$APPDIR/runtime/compat/usr/lib/x86_64-linux-gnu:$APPDIR/runtime/compat/usr/lib/x86_64-linux-gnu/gconv:$APPDIR/runtime/compat/usr/lib64
APPDIR_LIBC_VERSION=2.39
PYTHONHOME=$APPDIR/usr
PYTHONPATH=$APPDIR/usr/src:${PYTHONPATH}
APPDIR_PATH_MAPPINGS=/work/AppDir:$APPDIR;
APPDIR_LIBC_LINKER_PATH={'lib64/ld-linux-x86-64.so.2'}
